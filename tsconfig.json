{
  "extends": "@jmlweb/tsconfig-base",
  "compilerOptions": {
    "lib": ["ES2022"],
    "allowJs": true,
    "noEmit": true,
    "moduleDetection": "force",
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["coverage", "dist", "docs", "node_modules"]
}
